{
  "name": "@kongzijs/flf-builder",
  "version": "0.1.1",
  "description": "Visual React Flow based lesson builder editor components, fully implemented on the FLF specification.",
  "license": "MIT",
  "author": "KongziJS Contributors",
  "keywords": [
    "flf",
    "fluence",
    "lesson",
    "builder",
    "flow",
    "editor",
    "react",
    "kongzijs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kongzijs/kongzijs.git",
    "directory": "packages/flf-builder"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "style": "./dist/flf-builder.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/flf-builder.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite"
  },
  "dependencies": {
    "@borgtj/react": "^0.1.0",
    "@kongzijs/flf-core": "workspace:*",
    "@kongzijs/flf-i18n": "workspace:*",
    "@kongzijs/markdown-editor": "workspace:*",
    "@quizerjs/core": "^0.0.10",
    "@quizerjs/dsl": "^0.0.10",
    "@quizerjs/i18n": "^0.0.10",
    "@quizerjs/react": "^0.0.10",
    "@quizerjs/theme": "^0.0.10",
    "@xyflow/react": "^12.10.0",
    "lucide-react": "^0.487.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^28.1.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^2.1.9"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
