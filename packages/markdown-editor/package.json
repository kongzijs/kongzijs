{
  "name": "@kongzijs/markdown-editor",
  "version": "0.1.1",
  "description": "Tiptap-based rich Markdown editor component for authoring FLF lesson content within KongziJS.",
  "license": "MIT",
  "author": "KongziJS Contributors",
  "keywords": [
    "flf",
    "markdown",
    "editor",
    "tiptap",
    "rich-text",
    "kongzijs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kongzijs/kongzijs.git",
    "directory": "packages/markdown-editor"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "style": "./dist/markdown-editor.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/markdown-editor.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "test": "vitest run"
  },
  "dependencies": {
    "@kongzijs/flf-i18n": "workspace:*",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "lucide-react": "^0.487.0",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "jsdom": "^28.1.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
