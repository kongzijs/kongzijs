{
  "name": "@kongzijs/flf-core",
  "version": "0.1.1",
  "description": "Core FLF (Fluence Lesson Format) specification implementation — types, validators, and React Flow transformers.",
  "license": "MIT",
  "author": "KongziJS Contributors",
  "keywords": [
    "flf",
    "fluence",
    "lesson",
    "e-learning",
    "course",
    "lms",
    "kongzijs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kongzijs/kongzijs.git",
    "directory": "packages/flf-core"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react-swc": "^3.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^2.1.8"
  }
}
