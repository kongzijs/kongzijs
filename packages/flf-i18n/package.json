{
    "name": "@kongzijs/flf-i18n",
    "version": "0.1.0",
    "description": "Internationalisation (i18n) utilities and locale definitions for FLF-based KongziJS applications.",
    "license": "MIT",
    "author": "KongziJS Contributors",
    "keywords": [
        "flf",
        "fluence",
        "i18n",
        "internationalisation",
        "locale",
        "kongzijs"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/kongzijs/kongzijs.git",
        "directory": "packages/flf-i18n"
    },
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "test": "vitest run"
    },
    "peerDependencies": {
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "@vitejs/plugin-react-swc": "^3.10.2",
        "typescript": "^5.0.0",
        "vite": "^7.3.1",
        "vite-plugin-dts": "^4.5.3",
        "vitest": "^2.1.8"
    }
}
