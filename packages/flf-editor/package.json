{
    "name": "@kongzijs/flf-editor",
    "version": "0.1.0",
    "description": "Monaco-based code editor component for editing FLF JSON and Quiz DSL within KongziJS applications.",
    "license": "MIT",
    "author": "KongziJS Contributors",
    "keywords": [
        "flf",
        "fluence",
        "editor",
        "monaco",
        "code",
        "kongzijs"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/kongzijs/kongzijs.git",
        "directory": "packages/flf-editor"
    },
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build": "vite build",
        "dev": "vite"
    },
    "dependencies": {
        "@monaco-editor/react": "^4.6.0",
        "monaco-editor": "^0.52.2"
    },
    "devDependencies": {
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react-swc": "^3.10.2",
        "typescript": "^5.0.0",
        "vite": "^7.3.1",
        "vite-plugin-dts": "^4.5.3"
    },
    "peerDependencies": {
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    }
}
